# =========================
# Supabase
# =========================

# URL del proyecto de Supabase (ej: https://xxxx.supabase.co).
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública anon de Supabase para uso en cliente.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =========================
# App / Runtime
# =========================

# URL base pública del sitio (ej: http://localhost:3000 en local).
NEXT_PUBLIC_SITE_URL=

# Entorno de ejecución: development, test o production.
NODE_ENV=

# Habilita análisis de bundle en build (true/false).
ANALYZE=

# =========================
# Email (Resend)
# =========================

# API key de Resend para envío de correos transaccionales.
RESEND_API_KEY=

# Email de destino para formularios de contacto/reportes.
CONTACT_EMAIL=

# Remitente mostrado al enviar emails (ej: ReviUy <noreply@dominio.com>).
FROM_EMAIL=

# =========================
# Rate Limiting (Upstash Redis)
# =========================

# URL REST de la instancia Redis de Upstash.
UPSTASH_REDIS_REST_URL=

# Token REST de Upstash Redis.
UPSTASH_REDIS_REST_TOKEN=

# =========================
# SonarQube / SonarCloud
# =========================

# Organización de SonarCloud/SonarQube.
sonar.organization=

# Clave única del proyecto analizado en Sonar.
sonar.projectKey=

# Rutas fuente a analizar por Sonar (ej: src).
sonar.sources=

# URL del servidor Sonar (ej: https://sonarcloud.io).
sonar.host.url=

# =========================
# Google Sheets (Service Account)
# =========================

# ID de la planilla (valor entre /d/ y /edit en la URL de Google Sheets).
GOOGLE_SHEETS_ID=

# Email de la service account de Google Cloud.
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Clave privada de la service account.
# Mantener \n literales para saltos de línea en archivos .env.
GOOGLE_PRIVATE_KEY=

# =========================
# PostgreSQL
# =========================

# Usuario de la base de datos PostgreSQL.
DB_USER=

# Password del usuario de PostgreSQL.
DB_PASSWORD=

# Nombre de la base de datos PostgreSQL.
DB_NAME=

# Puerto de conexión PostgreSQL (ej: 5432).
DB_PORT=
