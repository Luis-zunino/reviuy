{
  "name": "reviuy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit --pretty",
    "migrations": "npx supabase db push",
    "supabase:typeLocal": "npx supabase gen types typescript --local > src/types/supabase/supabase.ts",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status",
    "supabase:reset": "npx supabase db reset",
    "supabase:migrate": "npx supabase migration up",
    "supabase:diff": "npx supabase db diff",
    "db:lint": "npx supabase db lint --local --level warning --fail-on error",
    "db:test:rls": "bash scripts/db-test-rls.sh",
    "db:test:static": "bash scripts/db-test-migrations-static.sh",
    "db:test:security": "yarn db:test:static && yarn db:test:rls",
    "db:setup": "npx supabase start && npx supabase db reset",
    "prepare": "husky",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "analyze": "ANALYZE=true next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "precommit": "python -m pre_commit run --all-files",
    "security:semgrep": "semgrep scan --config p/owasp-top-ten --config p/javascript --config p/typescript --config p/secrets --error --exclude node_modules --exclude .next .",
    "security:deps": "pnpm audit",
    "security:owasp": "pnpm security:semgrep && pnpm security:deps"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@next/bundle-analyzer": "^16.2.6",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.12",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bad-words": "^4.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^11.0.0",
    "leaflet": "^1.9.4",
    "leaflet-defaulticon-compatibility": "^0.1.2",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.7",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.75.0",
    "react-leaflet": "^5.0.0",
    "resend": "^6.12.3",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.7.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "sonarqube-scanner": "^4.3.6",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@11.1.1",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "resolutions": {
    "diff": "8.0.3",
    "@isaacs/brace-expansion": "5.0.1",
    "@modelcontextprotocol/sdk": "1.26.0",
    "sirv": "3.0.2",
    "qs": "6.14.2",
    "next": "16.2.5",
    "minimatch": "3.1.4",
    "hono": "4.12.4",
    "@hono/node-server": "1.19.10",
    "express-rate-limit": "8.2.2",
    "flatted": "3.4.2",
    "picomatch": "4.0.2"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "3.1.4",
      "hono": "4.12.4",
      "@hono/node-server": "1.19.10",
      "express-rate-limit": "8.2.2",
      "flatted": "3.4.2",
      "picomatch": "4.0.2",
      "axios": "1.15.2"
    }
  }
}